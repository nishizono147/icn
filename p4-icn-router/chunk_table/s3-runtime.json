{
    "target": "bmv2",
    "p4info": "build/switch.p4.p4info.txtpb",
    "bmv2_json": "build/switch.json",
    "table_entries": [
      {
        "table": "MyIngress.switch_config",
        "match": {
          "hdr.ethernet.etherType": [34997]
        },
        "action_name": "MyIngress.set_local_switch_id",
        "action_params": {
          "switch_id": 3
        }
      },
      {
        "table": "MyIngress.switch_config",
        "match": {
          "hdr.ethernet.etherType": [34998]
        },
        "action_name": "MyIngress.set_local_switch_id",
        "action_params": {
          "switch_id": 3
        }
      },
      {
        "table": "MyIngress.foward_interest",
        "match": {
          "hdr.ethernet.srcAddr": [
            "08:00:00:00:02:00"
          ]
        },
        "action_name": "MyIngress.dup_interest",
        "action_params": {
          "dstAddr": "08:00:00:00:02:22",
          "port": 1
        }
      }
    ],
    "clone_session_entries": [
      {
        "clone_session_id": 100,
        "replicas": [
          {
            "egress_port": 2,
            "instance": 1
          }
        ]
      }
    ]
  }
